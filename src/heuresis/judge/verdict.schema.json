{
  "type": "object",
  "required": ["decision", "reasoning", "evidence_refs"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["valid", "suspicious_evidence", "invalid_idea"]
    },
    "reasoning": {
      "type": "string",
      "minLength": 10
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
