# Copy to .env and fill in values locally. Do not commit .env.
#
#   cp .env.example .env
#
# Heuresis loads repo-local .env files with python-dotenv. For multi-key Gemini
# rate-limit rotation, use GEMINI_API_KEYS.

# Gemini / Google GenAI — use GEMINI_API_KEYS for multiple keys.
GEMINI_API_KEYS=
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Other agent / provider keys (passed through to sandboxes when set).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CURSOR_API_KEY=
HF_TOKEN=
